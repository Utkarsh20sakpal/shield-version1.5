# ──────────────────────────────────────────────────────────────────────────────
#  SERVER — copy this file to server/.env and fill in values
# ──────────────────────────────────────────────────────────────────────────────

# Server port (Render injects PORT automatically; leave as 5000 for local dev)
PORT=5000

# MongoDB connection string (use MongoDB Atlas for cloud)
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/sheild_iot

# JSON Web Token secret — use a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret

# URL of the deployed frontend (used for CORS whitelist in production)
# Example: https://shield-client.onrender.com
CLIENT_ORIGIN=http://localhost:5173

# Email credentials for alert notifications (Gmail recommended)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
